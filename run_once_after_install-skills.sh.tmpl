#!/usr/bin/env bash
# Install agent skills and agents via agentspec CLI
set -euo pipefail

if ! command -v agentspec &>/dev/null; then
    echo "Installing agentspec..."
    curl -fsSL https://raw.githubusercontent.com/urmzd/agentspec/main/scripts/install.sh | sh
fi

echo "Installing agent resources..."

# Local skills and agents from dotfiles repo (dot_agents/ → ~/.agents/)
agentspec manage add "{{ .chezmoi.sourceDir }}/dot_agents" --all-tools

# Third-party skills
agentspec manage add vercel-labs/skills --all-tools
agentspec manage add vercel/ai-elements --all-tools
agentspec manage add vercel/streamdown --all-tools
agentspec manage add google-gemini/gemini-skills --all-tools
agentspec manage add better-auth/skills@better-auth/best-practices --all-tools
agentspec manage add vercel/ai@skills/use-ai-sdk --all-tools
agentspec manage add fastapi/fastapi@fastapi/.agents/skills/fastapi --all-tools

# Sync: discover, link, and verify all resources
agentspec sync --fast

echo "Agent resources installed successfully."
