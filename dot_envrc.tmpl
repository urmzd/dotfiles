#!/usr/bin/env bash
# Global ~/.envrc — managed by chezmoi.
#
# Global tools (git, gh, fzf, jq, terraform, kubectl, ...) come from
# Homebrew (macOS) or apt/dnf/pacman (Linux), so this file does NOT need
# to load anything dev-tool-related — they're already on $PATH from .zshenv.
#
# Per-project .envrc files inherit nothing from here automatically; use
# direnv's `source_up` if you want to chain (see dot_envrc.project.example).

# Source machine-specific overrides if present (not managed by chezmoi).
# Create ~/.envrc.local for personal env vars (API tokens, default warehouse, etc.)
[[ -f ~/.envrc.local ]] && source_env ~/.envrc.local
