#!/usr/bin/env zsh

# Enable direnv hook BEFORE oh-my-zsh so per-directory env vars apply.
{{ if lookPath "direnv" -}}
export DIRENV_LOG_FORMAT=""
eval "$(direnv hook zsh)"
{{- end }}

# Enable Powerlevel10k instant prompt AFTER environment is set.
# Disable when using direnv or tmux to prevent conflicts.
if [[ -z "$TMUX" && -z "$DIRENV_DIR" && -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH=$HOME/.oh-my-zsh
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(git zsh-syntax-highlighting zsh-completions)

# Load Homebrew-installed completion scripts (e.g., just) before compinit
{{- if and .is_macos (eq .chezmoi.arch "arm64") }}
[[ -d "/opt/homebrew/share/zsh/site-functions" ]] && \
  fpath=("/opt/homebrew/share/zsh/site-functions" $fpath)
{{- else if and .is_macos (eq .chezmoi.arch "amd64") }}
[[ -d "/usr/local/share/zsh/site-functions" ]] && \
  fpath=("/usr/local/share/zsh/site-functions" $fpath)
{{- end }}

fpath+=${ZSH_CUSTOM:-${ZSH:-~/.oh-my-zsh}/custom}/plugins/zsh-completions/src

# Pre-generated completions (from chezmoi apply)
[[ -f "$HOME/.zsh/brew-fpath.zsh" ]] && source "$HOME/.zsh/brew-fpath.zsh"
[[ -d "$HOME/.zsh/completions" ]] && fpath=("$HOME/.zsh/completions" $fpath)

# Initialize completions (use cached dump unless stale >24h)
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# Load oh-my-zsh AFTER environment is properly set
source "$ZSH/oh-my-zsh.sh"

# Enable colors for ls - Cyberdream theme
# Load AFTER oh-my-zsh to prevent it from being overridden
{{- if .is_macos }}
# macOS: prefer GNU coreutils (gls/gdircolors from Homebrew), fall back to BSD ls.
# Cyberdream colors: blue (#5ea1ff), green (#5eff6c), cyan (#5ef1ff), magenta (#bd5eff)
if command -v gdircolors >/dev/null 2>&1; then
  eval "$(gdircolors -b)"
  # Customize LS_COLORS with Cyberdream palette (256-color codes)
  # di=38;5;75 (blue dirs), ex=38;5;83 (green executables), ln=38;5;87 (cyan symlinks)
  export LS_COLORS="di=38;5;75:ex=38;5;83:ln=38;5;87:or=38;5;141:mi=38;5;203:*.archive=38;5;141:*.tar=38;5;141:*.tgz=38;5;141:*.arc=38;5;141:*.arj=38;5;141:*.taz=38;5;141:*.lha=38;5;141:*.lz4=38;5;141:*.lzh=38;5;141:*.lzma=38;5;141:*.tlz=38;5;141:*.txz=38;5;141:*.tzo=38;5;141:*.t7z=38;5;141:*.zip=38;5;141:*.z=38;5;141:*.dz=38;5;141:*.gz=38;5;141:*.lrz=38;5;141:*.lz=38;5;141:*.lzop=38;5;141:*.xz=38;5;141:*.zst=38;5;141:*.zstd=38;5;141:*.bz2=38;5;141:*.bz=38;5;141:*.tbz=38;5;141:*.tbz2=38;5;141:*.tz=38;5;141:*.deb=38;5;141:*.rpm=38;5;141:*.jar=38;5;141:*.war=38;5;141:*.ear=38;5;141:*.rar=38;5;141:*.aces=38;5;141:*.7z=38;5;141:*.ace=38;5;141:*.apk=38;5;141:*.cpio=38;5;141:*.iso=38;5;141:*.cab=38;5;141:*.img=38;5;141:*.msi=38;5;141"
  alias ls='gls --color=auto'
elif ls --color=auto &>/dev/null 2>&1; then
  # GNU ls available
  if command -v dircolors >/dev/null 2>&1; then
    eval "$(dircolors -b)"
  fi
  # Customize LS_COLORS with Cyberdream palette
  export LS_COLORS="di=38;5;75:ex=38;5;83:ln=38;5;87:or=38;5;141:mi=38;5;203:*.archive=38;5;141:*.tar=38;5;141:*.tgz=38;5;141:*.arc=38;5;141:*.arj=38;5;141:*.taz=38;5;141:*.lha=38;5;141:*.lz4=38;5;141:*.lzh=38;5;141:*.lzma=38;5;141:*.tlz=38;5;141:*.txz=38;5;141:*.tzo=38;5;141:*.t7z=38;5;141:*.zip=38;5;141:*.z=38;5;141:*.dz=38;5;141:*.gz=38;5;141:*.lrz=38;5;141:*.lz=38;5;141:*.lzop=38;5;141:*.xz=38;5;141:*.zst=38;5;141:*.zstd=38;5;141:*.bz2=38;5;141:*.bz=38;5;141:*.tbz=38;5;141:*.tbz2=38;5;141:*.tz=38;5;141:*.deb=38;5;141:*.rpm=38;5;141:*.jar=38;5;141:*.war=38;5;141:*.ear=38;5;141:*.rar=38;5;141:*.aces=38;5;141:*.7z=38;5;141:*.ace=38;5;141:*.apk=38;5;141:*.cpio=38;5;141:*.iso=38;5;141:*.cab=38;5;141:*.img=38;5;141:*.msi=38;5;141"
  alias ls='ls --color=auto'
else
  # BSD ls (default macOS) - use LSCOLORS format
  alias ls='ls -G'
  export CLICOLOR=1
  # Cyberdream BSD equivalent: directories=blue (B), executables=green (x)
  export LSCOLORS=BxGxfxfxCxCxBxBxBxBxEx
fi
{{- else }}
# Linux: use GNU coreutils
if command -v dircolors >/dev/null 2>&1; then
  eval "$(dircolors -b)"
fi
alias ls='ls --color=auto'
{{- end }}

export EDITOR='nvim'

alias vi="nvim"
alias vim="nvim"

# Dotfiles management

# Set a flat `key = value` under [data] in a chezmoi TOML config, keeping indent.
_dotfiles_toml_set() {
  local file=$1 key=$2 val=$3
  grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$file" || return 1
  awk -v k="$key" -v v="$val" '
    $0 ~ ("^[[:space:]]*" k "[[:space:]]*=") { sub(/=.*/, "= " v); print; next }
    { print }
  ' "$file" > "$file.dfw" && mv "$file.dfw" "$file"
}

# Interactive package-group + exclude editor (backs `dotfiles update groups`).
_dotfiles_update_groups() {
  local cfg=$1
  command -v fzf >/dev/null && command -v jq >/dev/null || {
    echo "❌ 'update groups' needs fzf and jq installed."; return 1
  }
  [ -f "$cfg" ] || { echo "❌ No chezmoi config at $cfg"; return 1; }
  if ! grep -qE '^[[:space:]]*install_cloud[[:space:]]*=' "$cfg"; then
    echo "Package flags not in config yet; running 'dotfiles config' first..."
    chezmoi init || return 1
  fi
  local data; data="$(chezmoi data --format=json 2>/dev/null)"
  local -A state desc
  state[cloud]=$(print -r -- "$data" | jq -r '.install_cloud // false')
  state[fonts]=$(print -r -- "$data" | jq -r '.install_fonts // false')
  state[mobile]=$(print -r -- "$data" | jq -r '.install_mobile // false')
  local excl; excl=$(print -r -- "$data" | jq -r '.pkg_exclude // ""')
  desc[cloud]="docker, colima, kubectl, helm, k9s, terraform, runpodctl"
  desc[fonts]="Monaspace + Iosevka Nerd Fonts"
  desc[mobile]="Android Studio + SDK + CocoaPods"
  local order=(cloud fonts mobile) tab=$'\t'
  while true; do
    local menu="" g m
    for g in $order; do
      [[ ${state[$g]} == true ]] && m="●" || m="○"
      menu+="${g}${tab}${m} ${g}: ${desc[$g]}"$'\n'
    done
    menu+="__exclude${tab}✎ exclude list (current: ${excl:-none})"$'\n'
    menu+="__apply${tab}✓ save & apply"$'\n'
    menu+="__cancel${tab}✗ cancel"
    local pick
    pick=$(printf '%s' "$menu" | fzf --ansi --height=45% --reverse \
        --delimiter="$tab" --with-nth=2.. \
        --header='● on / ○ off. ENTER an item to toggle, then pick "save & apply"' \
        --prompt='groups> ' | cut -d"$tab" -f1)
    case "$pick" in
      cloud|fonts|mobile)
        [[ ${state[$pick]} == true ]] && state[$pick]=false || state[$pick]=true ;;
      __exclude) vared -p "Exclude (comma-separated): " excl ;;
      __apply) break ;;
      *) echo "Aborted (no changes)."; return 0 ;;
    esac
  done
  echo
  echo "New selection: cloud=${state[cloud]} fonts=${state[fonts]} mobile=${state[mobile]} exclude='${excl}'"
  _dotfiles_toml_set "$cfg" install_cloud  "${state[cloud]}"
  _dotfiles_toml_set "$cfg" install_fonts  "${state[fonts]}"
  _dotfiles_toml_set "$cfg" install_mobile "${state[mobile]}"
  _dotfiles_toml_set "$cfg" pkg_exclude    "\"${excl}\""
  echo "Applying..."
  chezmoi apply
}

function dotfiles() {
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi/chezmoi.toml"
  case "${1:-help}" in
    apply)
      if [ -z "$(chezmoi diff 2>/dev/null)" ]; then
        echo "✅ Already up to date."
        return 0
      fi
      chezmoi diff
      if [[ "${2:-}" == "-y" || "${2:-}" == "--yes" ]]; then
        chezmoi apply
        return
      fi
      if read -q "?Apply these changes? [y/N] "; then
        echo; chezmoi apply
      else
        echo; echo "Aborted."
      fi
      ;;
    diff)
      chezmoi diff
      ;;
    edit)
      cd ~/.local/share/chezmoi && ${EDITOR:-nvim} . && cd -
      ;;
    config)
      # Re-run the init prompts so newly added flags get picked up. Answered
      # promptOnce fields are kept; only new/missing ones are asked.
      echo "🔧 Re-running chezmoi prompts (existing answers kept)..."
      chezmoi init && chezmoi apply
      ;;
    update)
      case "${2:-all}" in
        all)
          echo "⬆️  Updating everything (brew packages + AI CLIs)..."
          brew update && brew upgrade
          rm -f "$HOME/.local/state/ai-tools-installed"
          chezmoi apply
          ;;
        packages|package|pkg)
          brew update && brew upgrade && chezmoi apply
          ;;
        groups|group)
          _dotfiles_update_groups "$cfg"
          ;;
        ai)
          rm -f "$HOME/.local/state/ai-tools-installed"
          chezmoi apply
          ;;
        *)
          echo "Usage: dotfiles update [packages|groups|ai]   (no arg = everything)"
          ;;
      esac
      ;;
    doctor)
      chezmoi doctor
      echo; echo "=== dotfiles tool versions ==="
      dotfiles status
      echo; echo "=== documentation hygiene ==="
      local docs_checker="$HOME/.agents/skills/sync-docs/scripts/check-doc-hygiene.sh"
      if [ -x "$docs_checker" ]; then
        "$docs_checker" "$(chezmoi source-path)"
      elif [ -x "$HOME/.local/share/chezmoi/dot_agents/skills/sync-docs/scripts/executable_check-doc-hygiene.sh" ]; then
        "$HOME/.local/share/chezmoi/dot_agents/skills/sync-docs/scripts/executable_check-doc-hygiene.sh" "$HOME/.local/share/chezmoi"
      else
        echo "documentation hygiene checker not installed"
      fi
      ;;
    status)
      echo "=== AI tool versions ==="
      echo -n "  claude: "; claude --version 2>/dev/null || echo "not installed"
      echo -n "  codex:  "; npm list -g @openai/codex 2>/dev/null | grep @openai/codex | awk '{print $2}' || echo "not installed"
      echo -n "  agy:    "; agy --version 2>/dev/null || echo "not installed"
      echo -n "  cortex: "; cortex --version 2>/dev/null || echo "not installed"
      ;;
    clean)
      echo "Quick disk cleanup -- removing regenerable build artifacts and caches..."
      echo "Before:"; df -h / | awk 'NR==1 || NR==2'; echo ""
      find "$HOME/github" -maxdepth 3 -name target -type d -exec rm -rf {} + 2>/dev/null
      find "$HOME/github" -maxdepth 3 -name node_modules -type d -exec rm -rf {} + 2>/dev/null
      go clean -cache 2>/dev/null; pip cache purge 2>/dev/null; uv cache clean 2>/dev/null
      find "$HOME/github" -maxdepth 4 -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null
      brew cleanup --prune=all -s 2>/dev/null
      echo "After:"; df -h / | awk 'NR==1 || NR==2'
      ;;
    *)
      echo "Usage: dotfiles <command>"
      echo ""
      echo "  apply             Preview diff, confirm, then apply  (-y skips confirm)"
      echo "  diff              Preview pending chezmoi changes"
      echo "  edit              Open dotfiles source in editor"
      echo "  config            Re-run chezmoi prompts to pick up new/changed flags"
      echo ""
      echo "  update            Update everything: brew packages + AI CLIs, then apply"
      echo "  update packages   brew upgrade + apply"
      echo "  update groups     Toggle package groups + excludes (fzf), then apply"
      echo "  update ai         Reinstall AI CLIs at pinned versions"
      echo ""
      echo "  doctor            chezmoi doctor + tool versions + documentation hygiene"
      echo "  status            Show installed AI tool versions"
      echo "  clean             Remove regenerable build artifacts and caches"
      ;;
  esac
}

# Kubernetes aliases (Colima with k3s)
alias k8s-up="colima start --kubernetes"
alias k8s-down="colima stop"

# Cloud authentication aliases
# GCP: User and application-default login
alias gcpsso="gcloud auth login && gcloud auth application-default login"

# Snowflake: Generate JWT and export as SNOWFLAKE_TOKEN
unalias snowsso 2>/dev/null
function snowsso() {
  local token
  token=$(snow connection generate-jwt) || { echo "Failed to generate JWT"; return 1; }
  export SNOWFLAKE_TOKEN="${token}"
  echo "SNOWFLAKE_TOKEN exported"
}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# FZF integration
{{ if lookPath "fzf" -}}
source <(fzf --zsh)
{{- end }}

# fnm (Fast Node Manager) adds node/npm shims to PATH, auto-switches on cd.
{{ if lookPath "fnm" -}}
eval "$(fnm env --use-on-cd --shell zsh)"
{{- end }}

# Load local environment if exists
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

# Source all function files from ~/.zsh/functions
if [[ -d "$HOME/.zsh/functions" ]]; then
  for func_file in "$HOME/.zsh/functions"/*.zsh(N); do
    source "$func_file"
  done
fi
