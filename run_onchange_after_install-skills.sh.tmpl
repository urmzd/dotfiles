#!/usr/bin/env bash
# Chezmoi run_onchange - Sync agent skills to ~/.claude/skills/
# Triggered by: {{ include "skills/audit-security/SKILL.md" | sha256sum }}
# {{ include "skills/build-cli/SKILL.md" | sha256sum }}
# {{ include "skills/choose-stack/SKILL.md" | sha256sum }}
# {{ include "skills/configure-ai/SKILL.md" | sha256sum }}
# {{ include "skills/create-llms-txt/SKILL.md" | sha256sum }}
# {{ include "skills/review-design/SKILL.md" | sha256sum }}
# {{ include "skills/scaffold-project/SKILL.md" | sha256sum }}
# {{ include "skills/setup-ci/SKILL.md" | sha256sum }}
# {{ include "skills/setup-devenv/SKILL.md" | sha256sum }}
# {{ include "skills/setup-release/SKILL.md" | sha256sum }}
# {{ include "skills/style-brand/SKILL.md" | sha256sum }}
# {{ include "skills/style-cli/SKILL.md" | sha256sum }}
# {{ include "skills/write-code/SKILL.md" | sha256sum }}
# {{ include "skills/write-readme/SKILL.md" | sha256sum }}

set -euo pipefail

SOURCE_SKILLS="{{ .chezmoi.sourceDir }}/skills"
TARGET_SKILLS="${HOME}/.claude/skills"

echo "Syncing agent skills from ${SOURCE_SKILLS} to ${TARGET_SKILLS}..."

mkdir -p "${TARGET_SKILLS}"

# Create symlinks for each skill in source (skip if non-dotfiles symlink exists)
for skill_dir in "${SOURCE_SKILLS}"/*/; do
    skill_name="$(basename "${skill_dir}")"
    target="${TARGET_SKILLS}/${skill_name}"

    # If target exists and is a symlink NOT pointing into our source, skip it
    if [ -L "${target}" ] && [[ "$(readlink "${target}")" != "${SOURCE_SKILLS}"* ]]; then
        echo "  skip: ${skill_name} (external symlink)"
        continue
    fi

    # Remove stale copy or old symlink pointing to us
    rm -rf "${target}"
    ln -s "${SOURCE_SKILLS}/${skill_name}" "${target}"
    echo "  link: ${skill_name}"
done

# Clean up symlinks in target that point into our source but no longer exist there
for entry in "${TARGET_SKILLS}"/*/; do
    [ -e "${entry}" ] || continue
    entry_name="$(basename "${entry}")"
    target="${TARGET_SKILLS}/${entry_name}"

    if [ -L "${target}" ] && [[ "$(readlink "${target}")" == "${SOURCE_SKILLS}"* ]]; then
        if [ ! -d "${SOURCE_SKILLS}/${entry_name}" ]; then
            rm "${target}"
            echo "  remove: ${entry_name} (no longer in source)"
        fi
    fi
done

echo "Agent skills synced successfully."
