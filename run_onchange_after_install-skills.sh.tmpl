# {{ include "skills/memory/SKILL.md" | sha256sum }}
# {{ include "skills/security-audit/SKILL.md" | sha256sum }}

set -euo pipefail

SOURCE_SKILLS="{{ .chezmoi.sourceDir }}/skills"
TARGET_SKILLS="${HOME}/.claude/skills"

echo "Syncing agent skills from ${SOURCE_SKILLS} to ${TARGET_SKILLS}..."

mkdir -p "${TARGET_SKILLS}"

for skill_dir in "${SOURCE_SKILLS}"/*/; do
    skill_name="$(basename "${skill_dir}")"
    mkdir -p "${TARGET_SKILLS}/${skill_name}"
    cp "${skill_dir}SKILL.md" "${TARGET_SKILLS}/${skill_name}/SKILL.md"
done

echo "Agent skills synced successfully."
