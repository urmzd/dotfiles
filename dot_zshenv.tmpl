#!/usr/bin/env zsh
# ~/.zshenv: Always sourced, sets up environment variables

# XDG Base Directory Specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# Editor configuration
export EDITOR='nvim'
export VISUAL='nvim'

# Ensure local bin is in PATH
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Rust toolchain (rustup)
if [ -d "$HOME/.cargo/bin" ]; then
    export PATH="$HOME/.cargo/bin:$PATH"
fi

# Google Cloud CLI (installed by run_onchange_after_install-cloud-clis.sh)
if [ -f "$HOME/.local/share/google-cloud-sdk/path.zsh.inc" ]; then
    . "$HOME/.local/share/google-cloud-sdk/path.zsh.inc"
fi

{{- if .is_personal }}
# Personal machine environment variables
# Add any personal-specific environment setup here
{{- end }}

{{- if .is_work }}
# Work machine environment variables
# Add any work-specific environment setup here
{{- end }}
