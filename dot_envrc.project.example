#!/usr/bin/env bash
# Example project-specific .envrc file
# Copy this to your project directory as .envrc and customize.
#
# IMPORTANT:
# - Add .envrc to your project's .gitignore to avoid committing environment files
# - Run 'direnv allow' in the project directory after creating/editing

# ============================================================================
# Inherit personal defaults (optional)
# ============================================================================
# Uncomment to chain ~/.envrc (which sources ~/.envrc.local) so personal
# defaults apply here. Without this, only the values below are loaded.

# source_up

# ============================================================================
# Python virtual environment (optional)
# ============================================================================
# Auto-creates and activates .venv/ on `cd` into this directory.

# layout python
# layout python python3.12

# ============================================================================
# Load .env file (optional)
# ============================================================================
# Reads KEY=VALUE pairs from a .env file. Pair with .gitignore.

# dotenv

# ============================================================================
# Add bin/ to PATH (optional)
# ============================================================================
# Useful for project-local scripts.

# PATH_add bin

# ============================================================================
# Snowflake project overrides
# ============================================================================
# These override defaults from ~/.envrc.local for this project.

export SNOWFLAKE_DATABASE="PROJECT_SPECIFIC_DATABASE"
export SNOWFLAKE_SCHEMA="PROJECT_SPECIFIC_SCHEMA"
export SNOWFLAKE_ROLE="PROJECT_SPECIFIC_ROLE"
# export SNOWFLAKE_WAREHOUSE="WH_PROJECT_LARGE"

# ============================================================================
# Project-specific environment variables
# ============================================================================

# export APP_ENV="development"
# export LOG_LEVEL="debug"
# export DATABASE_URL="postgresql://localhost:5432/mydb"
# export API_BASE_URL="https://api.example.com"

# ============================================================================
# Multi-environment example
# ============================================================================
# Switch settings based on git branch.

# if git branch --show-current | grep -q "prod"; then
#   export SNOWFLAKE_ROLE="PROD_ROLE"
#   export APP_ENV="production"
# else
#   export SNOWFLAKE_ROLE="DEV_ROLE"
#   export APP_ENV="development"
# fi

# ============================================================================
# Usage
# ============================================================================
# 1. cp ~/.local/share/chezmoi/dot_envrc.project.example /path/to/project/.envrc
# 2. Customize with your project settings
# 3. echo ".envrc" >> .gitignore
# 4. direnv allow
# 5. cd into directory and check: echo $SNOWFLAKE_DATABASE
