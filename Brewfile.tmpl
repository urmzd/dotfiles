# Brewfile - macOS packages managed by Homebrew
# Run: brew bundle --file=Brewfile
#
# Source of truth on macOS for everything except:
#   - gcloud / aws-cli   -> run_onchange_after_install-cloud-clis.sh.tmpl (pinned upstream)
#   - cortex             -> run_onchange_after_install-cortex.sh.tmpl   (pinned upstream)
#   - claude/codex/...   -> run_once_after_install-ai-clis.sh.tmpl       (npm/curl)
#   - Python / Rust      -> uv / rustup (curl-installed in run_once_before_install-packages-v2.sh.tmpl)
#
# Package selection is driven by prompts in .chezmoi.toml.tmpl: a `package_preset`
# (minimal/standard/full) sets defaults for the per-group flags `install_cloud`,
# `install_fonts`, and `install_mobile`, and `pkg_exclude` drops individual
# packages by name at install time. Set any of these via `chezmoi init` prompts
# or directly in ~/.config/chezmoi/chezmoi.toml, then re-run `chezmoi apply`.

{{- if .install_cloud }}
# Taps (third-party; core/cask are auto-tapped and need no declaration)
tap "hashicorp/tap"     # Official HashiCorp tap; core's terraform is frozen at 1.5.7 and disabled (BUSL relicense)
tap "runpod/runpodctl"  # RunPod CLI; public GitHub tap, no credentials/trust needed
{{- end }}

# Core CLI
brew "git"
brew "gh"
brew "fzf"
brew "ripgrep"
brew "tree"
brew "jq"
brew "yq"
brew "just"
brew "direnv"
brew "chezmoi"
brew "tmux"
brew "gnupg"
brew "tree-sitter-cli"
brew "uv"
brew "tealdeer"
brew "coreutils"  # Provides gls/gdircolors used in dot_zshrc.tmpl color setup
brew "reattach-to-user-namespace"  # tmux clipboard integration on macOS

{{- if .use_secrets }}

# Secrets
cask "1password-cli"  # `op` CLI; pairs with manage-secrets skill (1Password desktop app needed for biometric unlock)
{{- end }}

{{- if .install_cloud }}

# Cloud / infra (gated behind install_cloud flag)
brew "hashicorp/tap/terraform"  # From hashicorp/tap above; homebrew/core's terraform was disabled 2025-04-04
brew "colima"
brew "docker"
brew "docker-buildx"
brew "docker-compose"
brew "kubectl"
brew "helm"
brew "k9s"
brew "runpodctl"  # RunPod GPU cloud CLI (from runpod/runpodctl tap above)
{{- end }}

# Runtimes / language tooling
brew "fnm"            # Node version manager
brew "deno"
brew "go"
brew "golangci-lint"
brew "lua"
brew "luarocks"
brew "luacheck"
brew "stylua"

# Editor
brew "neovim", args: ["HEAD"]  # Extensible Vim-based text editor (0.12-dev)

# Build Tools
brew "cmake"    # Cross-platform build system generator
brew "gettext"  # GNU internationalization and localization support

{{- if .install_mobile }}

# Mobile Development (gated behind install_mobile flag)
cask "android-studio"            # Android IDE with SDK manager
cask "android-commandlinetools"  # Android SDK command-line tools
brew "cocoapods"                 # Dependency manager for Swift and Objective-C projects
{{- end }}

{{- if .install_fonts }}

# Fonts (gated behind install_fonts flag)
cask "font-monaspice-nerd-font"  # MonaspiceNe Nerd Font (Monaspace Neon; renamed from font-monaspace-nerd-font)
cask "font-iosevka-nerd-font"    # Iosevka Nerd Font (https://typeof.net/Iosevka/)
# cask "font-meslo-lg-nerd-font" # MesloLGS Nerd Font (legacy, replaced by MonaspiceNe)
{{- end }}

# Terminal
# Terminal: ghostty (installed outside Homebrew)
