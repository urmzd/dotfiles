# Shell integration (detect = auto-inject for zsh, enabled by default)
shell-integration = detect

# Font (matches Powerlevel10k setup)
font-family = MonaspiceNe Nerd Font
font-size = 13
adjust-cell-width = 0

# Window
window-padding-x = 4
window-padding-y = 4

# Theme (installed by bootstrap from cyberdream.nvim extras/ghostty)
theme = cyberdream
# Opacity high enough that text stays readable over white backgrounds;
# blur flattens whatever still bleeds through.
background-opacity = 0.92
background-blur-radius = 30
